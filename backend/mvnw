#!/bin/sh

BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
PROPERTIES_FILE="$WRAPPER_DIR/maven-wrapper.properties"
MAVEN_DIST_DIR="$WRAPPER_DIR/dists"
MAVEN_ZIP="$WRAPPER_DIR/apache-maven.zip"
MAVEN_HOME="$MAVEN_DIST_DIR/apache-maven-3.9.9"
MAVEN_CMD="$MAVEN_HOME/bin/mvn"

if [ ! -f "$PROPERTIES_FILE" ]; then
  echo "Cannot find $PROPERTIES_FILE"
  exit 1
fi

if [ ! -x "$MAVEN_CMD" ]; then
  echo "Downloading Maven Wrapper distribution..."
  mkdir -p "$MAVEN_DIST_DIR"
  DISTRIBUTION_URL="$(grep '^distributionUrl=' "$PROPERTIES_FILE" | sed 's/^distributionUrl=//')"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$DISTRIBUTION_URL" -o "$MAVEN_ZIP"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$DISTRIBUTION_URL" -O "$MAVEN_ZIP"
  else
    echo "curl or wget is required to download Maven."
    exit 1
  fi
  rm -rf "$MAVEN_HOME"
  unzip -q "$MAVEN_ZIP" -d "$MAVEN_DIST_DIR"
  rm -f "$MAVEN_ZIP"
fi

exec "$MAVEN_CMD" "$@"
